{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>bitwarden/renovate-config"
  ],
  "labels": ["t:deps"],
  "ignoreDeps": ["com.bitwarden:sdk-android"],
  "enabledManagers": [
    "github-actions",
    "gradle",
    "bundler"
  ],
  "packageRules": [
    {
      "groupName": "gh minor",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "groupName": "firebase",
      "description": "Firebase dependencies that must be updated together to maintain compatibility.",
      "matchManagers": [
        "gradle"
      ],
      "matchPackageNames": [
        "/com.google.firebase.*/",
        "/com.google.firebase/",
        "/com.google.gms.google-services/"
      ]
    },
    {
      "groupName": "kotlin",
      "description": "Kotlin and Compose dependencies that must be updated together to maintain compatibility.",
      "matchManagers": [
        "gradle"
      ],
      "matchPackageNames": [
        "/org.jetbrains.kotlin.*/",
        "/com.google.devtools.ksp/"
      ]
    }
  ]
}
